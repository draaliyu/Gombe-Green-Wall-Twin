# Gombe Desertification & Afforestation Intelligence Twin — Version 5
# Copy this file to .env for local development. Never commit .env.

# -----------------------------------------------------------------------------
# Copernicus Data Space: state/LGA Sentinel-2 NDVI and Sentinel-1 radar
# -----------------------------------------------------------------------------
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
COPERNICUS_PROCESS_URL=https://sh.dataspace.copernicus.eu/process/v1
SENTINEL_LOOKBACK_DAYS=35
SENTINEL_MAX_CLOUD_PERCENT=35
SATELLITE_REFRESH_SECONDS=21600
RADAR_REFRESH_SECONDS=21600

# -----------------------------------------------------------------------------
# Global Forest Watch
# -----------------------------------------------------------------------------
GFW_API_KEY=
GFW_ORIGIN=http://localhost
GFW_DATASET=umd_tree_cover_loss
GFW_DATASET_VERSION=latest
GFW_REFRESH_SECONDS=43200

# -----------------------------------------------------------------------------
# OpenWeather current conditions, forecast and weather-map tiles
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=
OPENWEATHER_CURRENT_URL=https://api.openweathermap.org/data/2.5/weather
OPENWEATHER_FORECAST_URL=https://api.openweathermap.org/data/2.5/forecast
OPENWEATHER_TILE_URL=https://tile.openweathermap.org/map/{layer}/{z}/{x}/{y}.png
WEATHER_REFRESH_SECONDS=300
WEATHER_CACHE_SECONDS=240

# -----------------------------------------------------------------------------
# Open-Meteo historical rainfall/reanalysis (no key required)
# -----------------------------------------------------------------------------
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
RAINFALL_HISTORY_DAYS=730
RAINFALL_REFRESH_SECONDS=21600

# -----------------------------------------------------------------------------
# NASA FIRMS thermal anomalies
# -----------------------------------------------------------------------------
NASA_FIRMS_MAP_KEY=
NASA_FIRMS_SOURCE=VIIRS_SNPP_NRT
NASA_FIRMS_AREA_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv/{map_key}/{source}/{bbox}/{days}
FIRMS_DAY_RANGE=3
FIRMS_REFRESH_SECONDS=3600

# -----------------------------------------------------------------------------
# Optional externally prepared evidence
# The platform works without these and labels its fallback as derived/modelled.
# -----------------------------------------------------------------------------
DYNAMIC_WORLD_STATS_URL=
DYNAMIC_WORLD_BEARER_TOKEN=
GEDI_CONTEXT_URL=
GEDI_BEARER_TOKEN=
GEDI_REFERENCE_AGBD_MG_HA=0
GEDI_REFERENCE_UNCERTAINTY_MG_HA=0

# -----------------------------------------------------------------------------
# Protected administration
# Use either ADMIN_PASSWORD or ADMIN_PASSWORD_SHA256, not both.
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=
ADMIN_PASSWORD_SHA256=
ADMIN_TOKEN_TTL_SECONDS=3600
PREDICTION_MIN_SAMPLES=24

# -----------------------------------------------------------------------------
# Study area, model and runtime
# west,south,east,north
# -----------------------------------------------------------------------------
AOI_BBOX=[10.55,10.20,11.85,11.55]
SIMULATION_INTERVAL_SECONDS=1
BROADCAST_INTERVAL_SECONDS=1
SIMULATION_GRID_WIDTH=96
SIMULATION_GRID_HEIGHT=72
RANDOM_SEED=4106
ENABLE_DEMO_DATA=true
DEBUG=false
